PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.rt4nqzs.mongodb.net/pandaemart?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key
NODE_ENV=development

# Production URLs (set these on Vercel). Localhost fallbacks are built into config/urls.js.
BACKEND_URL=https://pand-back.vercel.app
FRONTEND_URL=https://panda-panel-puce.vercel.app
ADMIN_APP_URL=https://panda-panel-puce.vercel.app
WEBSTORE_URL=https://pandaemart.com
CLIENT_URL=https://pandaemart.com

# Local development overrides (uncomment when testing locally):
# BACKEND_URL=http://localhost:5000
# FRONTEND_URL=http://localhost:3001
# ADMIN_APP_URL=http://localhost:3001
# WEBSTORE_URL=http://localhost:3000
# CLIENT_URL=http://localhost:3000

# Vercel: keep workers off (VERCEL is set automatically on Vercel)
ENABLE_WORKERS=false
ENABLE_TRACKING_WORKER=false

# PostEx Integration
POSTEX_API_TOKEN=your_postex_api_token
POSTEX_BASE_URL=https://api.postex.pk/services/integration/api/order

# Meta Integration (META_APP_SECRET backend only — never expose to frontend)
META_APP_ID=1295957769179348
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://pand-back.vercel.app/api/meta/oauth/callback
META_GRAPH_API_VERSION=v18.0
META_OAUTH_SCOPES=public_profile,ads_read,business_management,pages_show_list
META_ENCRYPTION_SECRET=dev_meta_secret_key_123

# Local Meta OAuth callback:
# META_REDIRECT_URI=http://localhost:5000/api/meta/oauth/callback
